/dts-v1/;
/plugin/;

/ {
    compatible = "ti,beaglebone", "ti,beaglebone-black";

    /* Part 1: Enable the McASP0 Hardware */
    fragment@0 {
        target = <&mcasp0>;
        __overlay__ {
            status = "okay";
            #sound-dai-cells = <0>;
            op-mode = <0>;
            tdm-slots = <2>;
            serial-dir = < 2 0 0 0 >;
            tx-num-evt = <32>;
            rx-num-evt = <32>;
        };
    };

    /* Part 2: Create the Virtual Soundcard & Force Clocks */
    fragment@1 {
        target-path = "/";
        __overlay__ {
            sound {
                compatible = "simple-audio-card";
                simple-audio-card,name = "INMP441-Mic";
                simple-audio-card,format = "i2s";

                /* Ensure BBB acts as the clock Master */
                simple-audio-card,bitclock-master = <&dailink0_master>;
                simple-audio-card,frame-master = <&dailink0_master>;

                /* Set the Master Clock to Frame Sync ratio */
                simple-audio-card,mclk-fs = <256>;

                dailink0_master: simple-audio-card,cpu {
                    sound-dai = <&mcasp0>;
                    /* Force the internal clock generator ON */
                    system-clock-frequency = <24576000>;
                };

                simple-audio-card,codec {
                    sound-dai = <&dmic_codec>;
                };
            };

            dmic_codec: dmic_codec {
                compatible = "dmic-codec";
                #sound-dai-cells = <0>;
            };
        };
    };
};